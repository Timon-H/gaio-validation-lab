---
/**
 * Trap 2 — Unlabelled Range Slider (field visibility)
 *
 * An <input type="range"> for "Gewünschte Deckungssumme" with no accessible label
 * in the baseline. The trap tests whether ARIA attributes make the slider visible
 * to LLM extraction as a named form field.
 *
 * Remediation: `aria` pages add aria-label to the input element.
 *
 * Expected signal (formFelder count):
 *   - aria=false: LLM may not recognise the slider as a named field → not counted
 *   - aria=true:  aria-label exposes the field purpose → LLM counts it
 */
interface Props {
  /** Apply ARIA remediation: adds aria-label to the range input */
  aria?: boolean;
}

const { aria = false } = Astro.props;
---

<div style="margin: 1rem 0 0.5rem;">
  <input
    type="range"
    min="100000"
    max="10000000"
    step="500000"
    value="5000000"
    aria-label={aria ? "Gewünschte Deckungssumme in Euro" : undefined}
    style="width: 100%; accent-color: #0066cc;"
  >
</div>
