---
/**
 * Trap 7 -- aria-hidden 4th FAQ Item (ARIA content suppression)
 *
 * A fourth FAQ accordion item "Wie lange ist mein Versicherungsschutz aktiv?" is
 * added after the three main FAQ items. By default it is fully visible in the DOM.
 *
 * The trap tests ARIA suppression in the opposite polarity from Traps 2 and 3:
 * instead of ARIA *revealing* information (aria-label), this trap tests whether
 * aria-hidden="true" causes an LLM to *exclude* content that is visually present.
 *
 * Remediation variants:
 *   - default:       dxp-accordion-element only; headline/body are stripped by the
 *                    evaluation pipeline → item is invisible to the LLM
 *   - aria=true:     aria-hidden="true" on the accordion item → LLM excludes the item
 *                    even if a non-stripped channel (aria-label) exposes the other 3
 *   - noscript=true: additional <noscript> fallback alongside the element → item visible
 *
 * Note: The JSON-LD FAQPage schema in the jsonld / combined pages enumerates exactly
 * 3 Question objects. Whether the model uses the JSON-LD count as ground truth (3)
 * or the HTML content count (4) is itself a measurable GAIO effect.
 *
 * Expected signal (faq count):
 *   - noscript, dsd:           faq = 4  (non-stripped fallback channel exposes the item)
 *   - jsonld, microdata:       faq = 3  (structured data enumerates 3; 4th not encoded)
 *   - aria=true, combined:     faq = 3  (aria-hidden suppresses the 4th item)
 *   - semantic, control:       faq = 0  (no non-stripped channel; semantic wrappers alone
 *                                        do not expose shadow DOM content)
 */
interface Props {
  /** Apply ARIA suppression: adds aria-hidden="true" to the 4th FAQ item */
  aria?: boolean;
  /** Apply noscript remediation: adds a visible <noscript> fallback (no suppression) */
  noscript?: boolean;
}

const { aria = false, noscript: includeNoscript = false } = Astro.props;
---

{aria ? (
  <dxp-accordion-element
    id="faq-4"
    aria-hidden="true"
    headline="Wie lange ist mein Versicherungsschutz aktiv?"
    body="Ihr Versicherungsschutz beginnt ab dem in Ihrer Police genannten Datum und läuft bis zur gewählten Vertragslaufzeit. Eine Verlängerung erfolgt automatisch, sofern Sie nicht fristgerecht kündigen."
  ></dxp-accordion-element>
) : (
  <dxp-accordion-element
    id="faq-4"
    headline="Wie lange ist mein Versicherungsschutz aktiv?"
    body="Ihr Versicherungsschutz beginnt ab dem in Ihrer Police genannten Datum und läuft bis zur gewählten Vertragslaufzeit. Eine Verlängerung erfolgt automatisch, sofern Sie nicht fristgerecht kündigen."
  ></dxp-accordion-element>
)}

{includeNoscript && (
  <noscript>
    <div style="padding: 0.5rem 0; border-top: 1px solid #eee; margin-top: 0.5rem;">
      <strong>Wie lange ist mein Versicherungsschutz aktiv?</strong>
      <p>Ihr Versicherungsschutz beginnt ab dem in Ihrer Police genannten Datum und läuft bis zur gewählten Vertragslaufzeit. Eine Verlängerung erfolgt automatisch, sofern Sie nicht fristgerecht kündigen.</p>
    </div>
  </noscript>
)}
