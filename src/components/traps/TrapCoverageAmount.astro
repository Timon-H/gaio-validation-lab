---
/**
 * Trap 2 — Unlabelled Number Input (field visibility)
 *
 * A number input for "Gewünschte Deckungssumme" with no accessible label
 * in the baseline. The trap tests whether ARIA attributes make the field visible
 * to LLM extraction as a named form field.
 *
 * Note: type="number" is used instead of type="range" because LLMs do not
 * reliably classify range sliders as form fields regardless of ARIA labeling.
 * A number input without a label (non-ARIA) vs. with aria-label (ARIA) creates
 * a clean discriminating signal.
 *
 * Remediation: `aria` pages add aria-label to the input element.
 *
 * Expected signal (formFelder count):
 *   - aria=false: LLM may not recognise the unlabelled number input as a named field
 *   - aria=true:  aria-label exposes the field purpose → LLM counts it
 */
interface Props {
  /** Apply ARIA remediation: adds aria-label to the number input */
  aria?: boolean;
}

const { aria = false } = Astro.props;
---

<div style="margin: 1rem 0 0.5rem;">
  <input
    type="number"
    name="f_coverage"
    min="100000"
    max="10000000"
    step="500000"
    value="5000000"
    aria-label={aria ? "Gewünschte Deckungssumme in Euro" : undefined}
    style="border: 1px solid #ccc; padding: 0.4rem 0.6rem; border-radius: 4px; width: 160px;"
  >
</div>