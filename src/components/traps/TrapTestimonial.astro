---
/**
 * Trap 4 — Testimonial Price Noise (tariff scope)
 *
 * A customer testimonial quote placed directly adjacent to the tariff comparison
 * block. The quote contains a price figure ("12 € pro Monat") that could be confused
 * with a bookable tariff by a naive text extractor.
 *
 * Non-semantic variant: the text is phrased as a first-person product statement
 * ("Bei meiner Police zahle ich nur 12 €…") which is plausible as a tariff price.
 * There is no comparative phrasing that would pre-disambiguate it for an LLM.
 *
 * Remediation variants:
 *   - semantic=true:  wraps in <figure>/<blockquote>/<figcaption> — semantic quotation landmarks
 *   - default:        bare <p> — no quotation semantics
 *
 * Note: The JSON-LD variant provides an alternative signal — the schema Offer list in
 * <head> enumerates exactly 3 offers, providing a machine-readable contract that
 * implicitly excludes the testimonial price. This is handled in the page's JSON-LD,
 * not in this component.
 *
 * Expected signal (tarife count / accuracy):
 *   - semantic=false: LLM may treat "12 €" as a fourth tariff
 *   - semantic=true:  <blockquote> signals a quotation, not a product offer
 */
interface Props {
  /** Apply semantic remediation: wraps in <figure>/<blockquote> instead of <p> */
  semantic?: boolean;
}

const { semantic = false } = Astro.props;
const quotePrefix = "Bei meiner Police zahle ich nur ";
const quotePrice = "12 € pro Monat";
const quoteSuffix = " – das ist top!";
const authorText = "– Kundin Lisa M., München";
---

{
  semantic ? (
    <figure style="margin: 0.5rem 0; padding: 0.5rem 0.75rem; border-left: 3px solid #ddd;">
      <blockquote>
        <p style="font-size: 0.875rem; color: #555; margin: 0;">
          <em>
            &#x201E;{quotePrefix}
            <strong>{quotePrice}</strong>
            {quoteSuffix}&#x201C;
          </em>
        </p>
      </blockquote>
      <figcaption style="font-size: 0.75rem; color: #888; margin-top: 0.25rem;">
        {authorText}
      </figcaption>
    </figure>
  ) : (
    <p style="font-size: 0.875rem; color: #555; border-left: 3px solid #ddd; padding: 0.5rem 0.75rem; margin: 0.5rem 0;">
      <>
        <em>
          &#x201E;{quotePrefix}
          <strong>{quotePrice}</strong>
          {quoteSuffix}&#x201C;
        </em>
        <br />
      </>
      <small>{authorText}</small>
    </p>
  )
}
