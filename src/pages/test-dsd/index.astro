---
/**
 * Isolated Test: Declarative Shadow DOM (DSD) via @lit-labs/ssr
 * 
 * Uses @lit-labs/ssr to server-render the exact same Lit components used on
 * all other pages. The SSR output includes <template shadowrootmode="open">
 * (Declarative Shadow DOM), making shadow content visible in the initial HTML.
 * 
 * NO JSON-LD, NO ARIA on host, NO <noscript> fallbacks, NO semantic wrappers.
 * Isolates the effect of DSD on GAIObility — the Shadow DOM content
 * is present in the initial HTML, not deferred to JS.
 * 
 * Each component is rendered server-side via renderLitToString() and injected
 * with set:html. The output includes Lit hydration markers (<!--lit-part-->)
 * which are part of the technique as practitioners would encounter it.
 */
import { renderLitToString, html } from '../../lib/lit-ssr.ts';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Import all component side-effects (registers custom elements for SSR)
import '../../components/baseline/dxp-button.ts';
import '../../components/baseline/dxp-text-input.ts';
import '../../components/baseline/dxp-dropdown.ts';
import '../../components/baseline/dxp-input-radio.ts';
import '../../components/baseline/dxp-accordion.ts';
import '../../components/baseline/dxp-accordion-element.ts';
import '../../components/baseline/dxp-card.ts';
import '../../components/baseline/dxp-flyout.ts';
import '../../components/baseline/dxp-tariff-comparison.ts';

// Server-render each component section to DSD HTML strings
const buttonHtml = await renderLitToString(html`
  <dxp-button>Jetzt berechnen</dxp-button>
  <dxp-button variant="secondary">Mehr erfahren</dxp-button>
  <dxp-button disabled>Nicht verfügbar</dxp-button>
`);

const textInputHtml = await renderLitToString(html`
  <dxp-text-input
    label="Vorname"
    name="vorname"
    placeholder="Max"
    required
    required-error-text="Bitte geben Sie Ihren Vornamen ein."
  ></dxp-text-input>
  <dxp-text-input
    label="E-Mail"
    name="email"
    type="email"
    placeholder="max@example.de"
    regex="^[^@]+@[^@]+\.[^@]+$"
    regex-error-text="Bitte geben Sie eine gültige E-Mail-Adresse ein."
  ></dxp-text-input>
`);

const dropdownHtml = await renderLitToString(html`
  <dxp-dropdown-v1
    label="Versicherungstyp"
    name="versicherungstyp"
    placeholder="Bitte wählen..."
    options='[{"key":"haftpflicht","value":"Haftpflichtversicherung"},{"key":"kasko","value":"Kaskoversicherung"},{"key":"teilkasko","value":"Teilkaskoversicherung"}]'
    required
  ></dxp-dropdown-v1>
`);

const radioHtml = await renderLitToString(html`
  <dxp-input-radio
    label="Zahlungsweise"
    name="zahlungsweise"
    options='[{"value":"monatlich","label":"Monatlich"},{"value":"quartal","label":"Vierteljährlich"},{"value":"jaehrlich","label":"Jährlich"}]'
  ></dxp-input-radio>
`);

const accordionHtml = await renderLitToString(html`
  <dxp-accordion>
    <dxp-accordion-element id="faq-1">
      <span slot="headline">Was ist eine Haftpflichtversicherung?</span>
      <p>Eine Haftpflichtversicherung schützt Sie vor Schadensersatzansprüchen Dritter. Sie übernimmt die Kosten, wenn Sie versehentlich Schäden an Personen oder deren Eigentum verursachen.</p>
    </dxp-accordion-element>
    <dxp-accordion-element id="faq-2">
      <span slot="headline">Wie berechne ich meinen Beitrag?</span>
      <p>Ihr Beitrag hängt von verschiedenen Faktoren ab, wie z.B. Ihrem Alter, Ihrem Wohnort und dem gewünschten Versicherungsschutz. Nutzen Sie unseren Online-Rechner für eine individuelle Berechnung.</p>
    </dxp-accordion-element>
    <dxp-accordion-element id="faq-3">
      <span slot="headline">Kann ich meine Versicherung online kündigen?</span>
      <p>Ja, Sie können Ihre Versicherung jederzeit online über Ihr Kundenkonto kündigen. Die Kündigungsfrist beträgt in der Regel einen Monat zum Ende der Vertragslaufzeit.</p>
    </dxp-accordion-element>
  </dxp-accordion>
`);

const cardHtml = await renderLitToString(html`
  <dxp-card>
    <span slot="badge" style="background: #e3f2fd; color: #0066cc;">Empfohlen</span>
    <h3 slot="header-title">Privathaftpflicht</h3>
    <p slot="teaser-text">Umfassender Schutz für Ihren Alltag – ab 3,50 € im Monat.</p>
    <dxp-button slot="buttons">Jetzt abschließen</dxp-button>
  </dxp-card>
`);

const cardHtml2 = await renderLitToString(html`
  <dxp-card>
    <h3 slot="header-title">Hausratversicherung</h3>
    <p slot="teaser-text">Schützen Sie Ihr Hab und Gut gegen Einbruch, Feuer und Wasserschäden.</p>
    <dxp-button slot="buttons" variant="secondary">Details ansehen</dxp-button>
  </dxp-card>
`);

const flyoutHtml = await renderLitToString(html`
  <dxp-flyout flyout-position="left">
    <dxp-button slot="content" variant="secondary">Hilfe & Kontakt</dxp-button>
    <div slot="flyout" style="padding: 0.5rem;">
      <p style="margin: 0 0 0.5rem;"><strong>Kundenservice</strong></p>
      <p style="margin: 0;">Telefon: 0800 123 456 789</p>
      <p style="margin: 0;">Mo–Fr: 8:00–18:00 Uhr</p>
    </div>
  </dxp-flyout>
`);

const tariffHtml = await renderLitToString(html`
  <dxp-tariff-comparison
    headline="Unsere Tarife im Vergleich"
    sub-headline="Wählen Sie den passenden Schutz für Ihre Bedürfnisse"
    tariffs='{"prefix":"ab","productName":"Haftpflicht","suffix":"€","tariffData":[{"id":"basis","name":"Basis","period":"monthly","premium":"3,50","description":"Grundschutz","buttons":[{"label":"Auswählen"}],"moduleConfigs":[{"moduleReference":"deckung","moduleReferenceUuid":"1","value":{"selectedText":"5 Mio. €"}},{"moduleReference":"selbstbeteiligung","moduleReferenceUuid":"2","value":{"selectedText":"150 €"}}]},{"id":"komfort","name":"Komfort","period":"monthly","premium":"5,90","highlighted":true,"overline":"Beliebteste Wahl","description":"Erweiterter Schutz","buttons":[{"label":"Auswählen"}],"moduleConfigs":[{"moduleReference":"deckung","moduleReferenceUuid":"1","value":{"selectedText":"10 Mio. €"}},{"moduleReference":"selbstbeteiligung","moduleReferenceUuid":"2","value":{"selectedText":"0 €"}}]},{"id":"premium","name":"Premium","period":"monthly","premium":"9,80","description":"Rundum-Sorglos","buttons":[{"label":"Auswählen"}],"moduleConfigs":[{"moduleReference":"deckung","moduleReferenceUuid":"1","value":{"selectedText":"50 Mio. €"}},{"moduleReference":"selbstbeteiligung","moduleReferenceUuid":"2","value":{"selectedText":"0 €"}}]}],"moduleGroups":[{"name":"Leistungen","modules":[{"moduleName":"deckung","name":"Deckungssumme","uuid":"1"},{"moduleName":"selbstbeteiligung","name":"Selbstbeteiligung","uuid":"2"}]}]}'
  ></dxp-tariff-comparison>
`);
---

<BaseLayout 
  title="Isolated Test: Declarative Shadow DOM"
  description="DXP components rendered via @lit-labs/ssr Declarative Shadow DOM – server-side shadow content visible to crawlers without JavaScript."
>
  <!-- SSR-only: hydration intentionally omitted to avoid duplicate late client rendering. -->

  <div style="margin-top: 1.5rem;">
    <h2>Isolated Variable: Declarative Shadow DOM (DSD)</h2>
    <p>
      Same Lit components as all other test pages, but <strong>server-side rendered</strong> via 
      <code>@lit-labs/ssr</code>. Each component's Shadow DOM is serialized as 
      <code>&lt;template shadowrootmode="open"&gt;</code> — the content is 
      <strong>in the initial HTML response</strong>, not deferred to JavaScript.
    </p>
    <p style="padding: 0.5rem; background: #f3e5f5; border-left: 3px solid #9c27b0; font-size: 0.875rem;">
      <strong>Isolated variable:</strong> Declarative Shadow DOM via <code>@lit-labs/ssr</code>. 
      No JSON-LD, no semantic HTML wrappers, no ARIA on hosts, no &lt;noscript&gt; fallbacks.
    </p>
  </div>

  <!-- BUTTON — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Button</div>
    <Fragment set:html={buttonHtml} />
  </div>

  <!-- TEXT INPUT — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Text Input</div>
    <Fragment set:html={textInputHtml} />
  </div>

  <!-- ============================================ -->
  <!-- SLIDER: Deckungssumme — kein ARIA-Label       -->
  <!-- ============================================ -->
  <div style="margin: 1rem 0 0.5rem;">
    <input type="range" min="100000" max="10000000" step="500000" value="5000000"
           style="width: 100%; accent-color: #0066cc;">
  </div>

  <!-- DROPDOWN — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Dropdown</div>
    <Fragment set:html={dropdownHtml} />
  </div>

  <!-- RADIO — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Input Radio</div>
    <Fragment set:html={radioHtml} />
  </div>

  <!-- ============================================ -->
  <!-- GEBURTSJAHR — Label nur via CSS, kein HTML-Label -->
  <!-- ============================================ -->
  <style>
    .field-geburtsjahr::before {
      content: "Geburtsjahr";
      display: block;
      font-size: 0.875rem;
      font-weight: 600;
      color: #333;
      margin-bottom: 0.25rem;
    }
  </style>
  <div class="field-geburtsjahr" style="margin: 0.5rem 0 2rem;">
    <input type="text" name="geburtsjahr" inputmode="numeric" pattern="\d{4}" maxlength="4"
           style="border: 1px solid #ccc; padding: 0.4rem 0.6rem; border-radius: 4px; width: 120px;">
  </div>

  <!-- ACCORDION — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Accordion</div>
    <Fragment set:html={accordionHtml} />
  </div>

  <!-- CARD — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Card</div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem;">
      <Fragment set:html={cardHtml} />
      <Fragment set:html={cardHtml2} />
    </div>
  </div>

  <!-- FLYOUT — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Flyout</div>
    <Fragment set:html={flyoutHtml} />
  </div>

  <!-- TARIFF COMPARISON — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Tariff Comparison</div>
    <!-- Testimonial — Preis-Rauschen nahe Tarifbereich -->
    <p style="font-size: 0.875rem; color: #555; border-left: 3px solid #ddd; padding: 0.5rem 0.75rem; margin: 0.5rem 0;">
      <em>„Ich spare jetzt <strong>12 € pro Monat</strong> gegenüber meinem alten Anbieter – super Preis-Leistung!“</em><br>
      <small>– Kundin Lisa M., München</small>
    </p>
    <!-- Veralteter Tarif — kein semantischer Kontext -->
    <p style="font-size: 0.8rem; color: #767676; margin-bottom: 0.75rem;">
      Unser früherer Einsteiger-Tarif war ab <strong>1,99 €</strong> / Monat erhältlich – dieser Tarif ist nicht mehr buchbar.
    </p>
    <Fragment set:html={tariffHtml} />
  </div>

  <!-- ============================================ -->
  <!-- CROSS-SELL — kein semantischer Kontext (<div>)-->
  <!-- ============================================ -->
  <div style="margin: 2rem 0; padding: 1rem; background: #f9f9f9; border: 1px dashed #bbb; border-radius: 4px;">
    <p style="margin: 0 0 0.5rem; font-weight: 600; font-size: 0.875rem; color: #555;">Das könnte Sie auch interessieren</p>
    <p style="margin: 0 0 0.5rem;">Kombinieren Sie Ihren Schutz – <strong>KFZ-Haftpflicht</strong> bereits ab <strong>39,00 €</strong> monatlich verfügbar.</p>
    <ul style="margin: 0.25rem 0 0; padding-left: 1.5rem; font-size: 0.875rem;">
      <li>KFZ Basis – 39,00 € / Monat · Selbstbeteiligung: 500 €</li>
      <li>KFZ Komfort – 59,00 € / Monat · Selbstbeteiligung: 0 €</li>
    </ul>
  </div>

  <p style="margin-top: 2rem; padding: 1rem; background: #f0f0f0; border-left: 4px solid #9c27b0;">
    <strong>Hinweis:</strong> Diese Seite nutzt <code>@lit-labs/ssr</code> zur serverseitigen Darstellung der 
    identischen Lit-Komponenten. Der Shadow-DOM-Inhalt ist über 
    <code>&lt;template shadowrootmode="open"&gt;</code> im initialen HTML eingebettet. 
    Crawler sehen den vollständigen gerenderten Inhalt inkl. Lit-Hydration-Marker 
    (<code>&lt;!--lit-part--&gt;</code>).
    <br><br>
    <a href="/control">← Baseline (client-side Shadow DOM)</a> · 
    <a href="/combined">Alle Maßnahmen kombiniert →</a>
  </p>
</BaseLayout>
