---
/**
 * Isolated Test: Declarative Shadow DOM (DSD) via @lit-labs/ssr
 *
 * Uses @lit-labs/ssr to server-render the exact same Lit components used on
 * all other pages. The SSR output includes <template shadowrootmode="open">
 * (Declarative Shadow DOM), making shadow content visible in the initial HTML.
 *
 * NO JSON-LD, NO ARIA on host, NO <noscript> fallbacks, NO semantic wrappers.
 * Isolates the effect of DSD on AI extractability — the Shadow DOM content
 * is present in the initial HTML, not deferred to JS.
 *
 * Each component is rendered server-side via renderLitToString() and injected
 * with set:html. The output includes Lit hydration markers (<!--lit-part-->)
 * which are part of the technique as practitioners would encounter it.
 */
import { renderLitToString, html } from '../../lib/lit-ssr.ts';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  TrapAriaHiddenBonus,
  TrapBirthYear,
  TrapCoverageAmount,
  TrapCrossSell,
  TrapDeprecatedTariff,
  TrapTestimonial,
} from '../../components/traps/index.ts';
import {
  PAGE_TITLE, PAGE_DESCRIPTION, INTRO, BUTTONS, TEXT_INPUTS,
  DROPDOWN, RADIO, FAQS, TRAP_FAQ, CARDS, FLYOUT, TARIFF, FOOTER_LINK,
} from '../../data/content';

// Import all component side-effects (registers custom elements for SSR)
import '../../components/baseline/dxp-button.ts';
import '../../components/baseline/dxp-text-input.ts';
import '../../components/baseline/dxp-dropdown.ts';
import '../../components/baseline/dxp-input-radio.ts';
import '../../components/baseline/dxp-accordion.ts';
import '../../components/baseline/dxp-accordion-element.ts';
import '../../components/baseline/dxp-card.ts';
import '../../components/baseline/dxp-flyout.ts';
import '../../components/baseline/dxp-tariff-comparison.ts';

// Server-render each component section to DSD HTML strings
const buttonHtml = await renderLitToString(html`
  <dxp-button>${BUTTONS.primary}</dxp-button>
  <dxp-button variant="secondary">${BUTTONS.secondary}</dxp-button>
  <dxp-button disabled>${BUTTONS.disabled}</dxp-button>
`);

const textInputHtml = await renderLitToString(html`
  <dxp-text-input
    label=${TEXT_INPUTS.vorname.label}
    name=${TEXT_INPUTS.vorname.name}
    placeholder=${TEXT_INPUTS.vorname.placeholder}
    required
    required-error-text=${TEXT_INPUTS.vorname.requiredErrorText}
  ></dxp-text-input>
  <dxp-text-input
    label=${TEXT_INPUTS.email.label}
    name=${TEXT_INPUTS.email.name}
    type=${TEXT_INPUTS.email.type}
    placeholder=${TEXT_INPUTS.email.placeholder}
    regex=${TEXT_INPUTS.email.regex}
    regex-error-text=${TEXT_INPUTS.email.regexErrorText}
  ></dxp-text-input>
`);

const dropdownHtml = await renderLitToString(html`
  <dxp-dropdown-v1
    label=${DROPDOWN.label}
    name=${DROPDOWN.name}
    placeholder=${DROPDOWN.placeholder}
    options=${DROPDOWN.options}
    required
  ></dxp-dropdown-v1>
`);

const radioHtml = await renderLitToString(html`
  <dxp-input-radio
    label=${RADIO.label}
    name=${RADIO.name}
    options=${RADIO.options}
    default=${RADIO.default}
  ></dxp-input-radio>
`);

const accordionHtml = await renderLitToString(html`
  <dxp-accordion>
    ${FAQS.map(faq => html`
      <dxp-accordion-element
        id=${faq.id}
        headline=${faq.headline}
        body=${faq.body}
      ></dxp-accordion-element>
    `)}
    <!-- Trap 7 (TrapHiddenFaq) inlined here because Lit SSR requires template literals;
         the Astro component version is used on all non-SSR pages. -->
    <dxp-accordion-element
      id=${TRAP_FAQ.id}
      headline=${TRAP_FAQ.headline}
      body=${TRAP_FAQ.body}
    ></dxp-accordion-element>
  </dxp-accordion>
`);

const cardHtml = await renderLitToString(html`
  <dxp-card card-title=${CARDS[0].title} card-description=${CARDS[0].description}>
    <span slot="badge" style="background: #e3f2fd; color: #0066cc;">${CARDS[0].badge}</span>
    <dxp-button slot="buttons">${CARDS[0].button}</dxp-button>
  </dxp-card>
`);

const cardHtml2 = await renderLitToString(html`
  <dxp-card card-title=${CARDS[1].title} card-description=${CARDS[1].description}>
    <dxp-button slot="buttons" variant="secondary">${CARDS[1].button}</dxp-button>
  </dxp-card>
`);

const flyoutHtml = await renderLitToString(html`
  <dxp-flyout flyout-position=${FLYOUT.position} phone=${FLYOUT.phone} hours=${FLYOUT.hours}>
    <dxp-button slot="content" variant="secondary">${FLYOUT.button}</dxp-button>
  </dxp-flyout>
`);

const tariffHtml = await renderLitToString(html`
  <dxp-tariff-comparison
    headline=${TARIFF.headline}
    sub-headline=${TARIFF.subHeadline}
    tariffs=${TARIFF.data}
  ></dxp-tariff-comparison>
`);
---

<BaseLayout title={PAGE_TITLE} description={PAGE_DESCRIPTION}>
  <!-- SSR-only: hydration intentionally omitted to avoid duplicate late client rendering. -->

  <div style="margin-top: 1.5rem;">
    <h2>{INTRO.heading}</h2>
    <p>{INTRO.description}</p>
  </div>

  <!-- BUTTON — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <Fragment set:html={buttonHtml} />
  </div>

  <!-- TEXT INPUT — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <Fragment set:html={textInputHtml} />
  </div>

  <TrapCoverageAmount />

  <!-- DROPDOWN — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <Fragment set:html={dropdownHtml} />
  </div>

  <!-- RADIO — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <Fragment set:html={radioHtml} />
  </div>

  <TrapBirthYear />

  <!-- ACCORDION — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <Fragment set:html={accordionHtml} />
  </div>

  <!-- CARD — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem;">
      <Fragment set:html={cardHtml} />
      <Fragment set:html={cardHtml2} />
    </div>
  </div>

  <!-- FLYOUT — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <Fragment set:html={flyoutHtml} />
  </div>

  <!-- TARIFF COMPARISON — SSR'd with DSD -->
  <div style="margin: 2rem 0;">
    <TrapTestimonial />
    <TrapDeprecatedTariff />
    <TrapAriaHiddenBonus />
    <Fragment set:html={tariffHtml} />
  </div>

  <TrapCrossSell />

  <p style="margin-top: 2rem; padding: 1rem; background: #f0f0f0; border-left: 4px solid #4a5dc9;">
    <a href={FOOTER_LINK.href}>{FOOTER_LINK.text}</a>
  </p>
</BaseLayout>
