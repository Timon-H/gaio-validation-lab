---
/**
 * Isolated Test: Microdata Only
 *
 * Same components as Baseline (Shadow DOM, <div> wrappers, no JSON-LD, no ARIA),
 * but WITH Microdata attributes (itemscope, itemtype, itemprop) on wrapper elements.
 *
 * Isolates the effect of inline structured data (Microdata) on AI extractability.
 * Unlike JSON-LD (separate script block in head), Microdata weaves schema.org
 * annotations directly into the HTML markup.
 *
 * This enables a direct comparison: same vocabulary (schema.org),
 * different delivery mechanism (inline attributes vs. JSON blob).
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  TrapAriaHiddenBonus,
  TrapBirthYear,
  TrapCoverageAmount,
  TrapCrossSell,
  TrapDeprecatedTariff,
  TrapHiddenFaq,
  TrapTestimonial,
} from "../../components/traps/index.ts";
import {
  PAGE_TITLE,
  PAGE_DESCRIPTION,
  INTRO,
  BUTTONS,
  TEXT_INPUTS,
  DROPDOWN,
  RADIO,
  FAQS,
  CARDS,
  FLYOUT,
  TARIFF,
  FOOTER_LINK,
} from "../../data/content";
---

<BaseLayout title={PAGE_TITLE} description={PAGE_DESCRIPTION}>
  <script>
    import "../../components/baseline/index.ts";
  </script>

  <div style="margin-top: 1.5rem;">
    <h2>{INTRO.heading}</h2>
    <p>{INTRO.description}</p>
  </div>

  <!-- BUTTON -->
  <div style="margin: 2rem 0;">
    <dxp-button>{BUTTONS.primary}</dxp-button>
    <dxp-button variant="secondary">{BUTTONS.secondary}</dxp-button>
    <dxp-button disabled>{BUTTONS.disabled}</dxp-button>
  </div>

  <!-- TEXT INPUT — annotated as ContactPoint expectations -->
  <div style="margin: 2rem 0;" itemscope itemtype="https://schema.org/Person">
    <meta
      itemprop="description"
      content="Persönliche Angaben: Vorname und E-Mail-Adresse für ein individuelles Versicherungsangebot"
    />
    <dxp-text-input
      label={TEXT_INPUTS.vorname.label}
      name={TEXT_INPUTS.vorname.name}
      placeholder={TEXT_INPUTS.vorname.placeholder}
      required
      required-error-text={TEXT_INPUTS.vorname.requiredErrorText}
    ></dxp-text-input>
    <dxp-text-input
      label={TEXT_INPUTS.email.label}
      name={TEXT_INPUTS.email.name}
      type={TEXT_INPUTS.email.type}
      placeholder={TEXT_INPUTS.email.placeholder}
      regex={TEXT_INPUTS.email.regex}
      regex-error-text={TEXT_INPUTS.email.regexErrorText}></dxp-text-input>
  </div>

  <TrapCoverageAmount />

  <!-- DROPDOWN — annotated with product category -->
  <div style="margin: 2rem 0;" itemscope itemtype="https://schema.org/ItemList">
    <meta itemprop="name" content="Versicherungstyp" />
    <meta
      itemprop="description"
      content="Auswahl der Versicherungsart: Haftpflicht-, Kasko- oder Teilkaskoversicherung"
    />
    <div
      itemprop="itemListElement"
      itemscope
      itemtype="https://schema.org/ListItem"
    >
      <meta itemprop="position" content="1" /><meta
        itemprop="name"
        content="Haftpflichtversicherung"
      />
    </div>
    <div
      itemprop="itemListElement"
      itemscope
      itemtype="https://schema.org/ListItem"
    >
      <meta itemprop="position" content="2" /><meta
        itemprop="name"
        content="Kaskoversicherung"
      />
    </div>
    <div
      itemprop="itemListElement"
      itemscope
      itemtype="https://schema.org/ListItem"
    >
      <meta itemprop="position" content="3" /><meta
        itemprop="name"
        content="Teilkaskoversicherung"
      />
    </div>
    <dxp-dropdown-v1
      label={DROPDOWN.label}
      name={DROPDOWN.name}
      placeholder={DROPDOWN.placeholder}
      options={DROPDOWN.options}
      required></dxp-dropdown-v1>
  </div>

  <!-- RADIO — annotated with payment frequency options -->
  <div style="margin: 2rem 0;" itemscope itemtype="https://schema.org/ItemList">
    <meta itemprop="name" content="Zahlungsweise" />
    <meta
      itemprop="description"
      content="Zahlungsfrequenz für den Versicherungsbeitrag"
    />
    <div
      itemprop="itemListElement"
      itemscope
      itemtype="https://schema.org/ListItem"
    >
      <meta itemprop="position" content="1" /><meta
        itemprop="name"
        content="Monatlich"
      />
    </div>
    <div
      itemprop="itemListElement"
      itemscope
      itemtype="https://schema.org/ListItem"
    >
      <meta itemprop="position" content="2" /><meta
        itemprop="name"
        content="Vierteljährlich"
      />
    </div>
    <div
      itemprop="itemListElement"
      itemscope
      itemtype="https://schema.org/ListItem"
    >
      <meta itemprop="position" content="3" /><meta
        itemprop="name"
        content="Jährlich"
      />
    </div>
    <dxp-input-radio
      label={RADIO.label}
      name={RADIO.name}
      options={RADIO.options}
      default={RADIO.default}></dxp-input-radio>
  </div>

  <TrapBirthYear />

  <!-- ACCORDION / FAQ — annotated as FAQPage -->
  <div style="margin: 2rem 0;" itemscope itemtype="https://schema.org/FAQPage">
    <div itemprop="mainEntity" itemscope itemtype="https://schema.org/Question">
      <meta itemprop="name" content="Was ist eine Haftpflichtversicherung?" />
      <div
        itemprop="acceptedAnswer"
        itemscope
        itemtype="https://schema.org/Answer"
      >
        <meta
          itemprop="text"
          content="Eine Haftpflichtversicherung schützt Sie vor Schadensersatzansprüchen Dritter. Sie übernimmt die Kosten, wenn Sie versehentlich Schäden an Personen oder deren Eigentum verursachen."
        />
      </div>
    </div>
    <div itemprop="mainEntity" itemscope itemtype="https://schema.org/Question">
      <meta itemprop="name" content="Wie berechne ich meinen Beitrag?" />
      <div
        itemprop="acceptedAnswer"
        itemscope
        itemtype="https://schema.org/Answer"
      >
        <meta
          itemprop="text"
          content="Ihr Beitrag hängt von verschiedenen Faktoren ab, wie z.B. Ihrem Alter, Ihrem Wohnort und dem gewünschten Versicherungsschutz. Nutzen Sie unseren Online-Rechner für eine individuelle Berechnung."
        />
      </div>
    </div>
    <div itemprop="mainEntity" itemscope itemtype="https://schema.org/Question">
      <meta
        itemprop="name"
        content="Kann ich meine Versicherung online kündigen?"
      />
      <div
        itemprop="acceptedAnswer"
        itemscope
        itemtype="https://schema.org/Answer"
      >
        <meta
          itemprop="text"
          content="Ja, Sie können Ihre Versicherung jederzeit online über Ihr Kundenkonto kündigen. Die Kündigungsfrist beträgt in der Regel einen Monat zum Ende der Vertragslaufzeit."
        />
      </div>
    </div>
    <dxp-accordion>
      {
        FAQS.map((faq) => (
          <dxp-accordion-element
            id={faq.id}
            headline={faq.headline}
            body={faq.body}
          />
        ))
      }
      <TrapHiddenFaq />
    </dxp-accordion>
  </div>

  <!-- CARD — annotated as Product/Offer -->
  <div style="margin: 2rem 0;">
    <div
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem;"
    >
      <div itemscope itemtype="https://schema.org/Product">
        <meta itemprop="name" content="Privathaftpflicht" />
        <meta
          itemprop="description"
          content="Umfassender Schutz für Ihren Alltag – ab 3,50 € im Monat."
        />
        <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <meta itemprop="price" content="3.50" />
          <meta itemprop="priceCurrency" content="EUR" />
          <meta
            itemprop="description"
            content="Grundschutz – Deckungssumme 5 Mio. €, Selbstbeteiligung 150 €"
          />
        </div>
        <dxp-card
          card-title={CARDS[0].title}
          card-description={CARDS[0].description}
        >
          <span slot="badge" style="background: #e3f2fd; color: #0066cc;"
            >{CARDS[0].badge}</span
          >
          <dxp-button slot="buttons">{CARDS[0].button}</dxp-button>
        </dxp-card>
      </div>
      <div itemscope itemtype="https://schema.org/Product">
        <meta itemprop="name" content="Hausratversicherung" />
        <meta
          itemprop="description"
          content="Schützen Sie Ihr Hab und Gut gegen Einbruch, Feuer und Wasserschäden."
        />
        <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <meta itemprop="price" content="4.20" />
          <meta itemprop="priceCurrency" content="EUR" />
          <meta
            itemprop="description"
            content="Schutz gegen Einbruch, Feuer und Wasserschäden"
          />
        </div>
        <dxp-card
          card-title={CARDS[1].title}
          card-description={CARDS[1].description}
        >
          <dxp-button slot="buttons" variant="secondary"
            >{CARDS[1].button}</dxp-button
          >
        </dxp-card>
      </div>
    </div>
  </div>

  <!-- FLYOUT — annotated as ContactPoint -->
  <div
    style="margin: 2rem 0;"
    itemscope
    itemtype="https://schema.org/Organization"
  >
    <div
      itemprop="contactPoint"
      itemscope
      itemtype="https://schema.org/ContactPoint"
    >
      <meta itemprop="contactType" content="customer service" />
      <meta itemprop="telephone" content="+49-800-123-456-789" />
      <meta itemprop="hoursAvailable" content="Mo-Fr 08:00-18:00" />
    </div>
    <dxp-flyout
      flyout-position={FLYOUT.position}
      phone={FLYOUT.phone}
      hours={FLYOUT.hours}
    >
      <dxp-button slot="content" variant="secondary">{FLYOUT.button}</dxp-button
      >
    </dxp-flyout>
  </div>

  <!-- TARIFF COMPARISON — annotated as Offer list -->
  <div style="margin: 2rem 0;" itemscope itemtype="https://schema.org/WebPage">
    <meta itemprop="name" content="Haftpflichtversicherung – Tarifvergleich" />
    <TrapTestimonial />
    <TrapDeprecatedTariff />
    <TrapAriaHiddenBonus />
    <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <meta itemprop="name" content="Haftpflicht Basis" />
      <meta itemprop="price" content="3.50" />
      <meta itemprop="priceCurrency" content="EUR" />
      <meta
        itemprop="description"
        content="Grundschutz – Deckungssumme 5 Mio. €, Selbstbeteiligung 150 €"
      />
    </div>
    <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <meta itemprop="name" content="Haftpflicht Komfort" />
      <meta itemprop="price" content="5.90" />
      <meta itemprop="priceCurrency" content="EUR" />
      <meta
        itemprop="description"
        content="Erweiterter Schutz – Deckungssumme 10 Mio. €, keine Selbstbeteiligung"
      />
    </div>
    <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <meta itemprop="name" content="Haftpflicht Premium" />
      <meta itemprop="price" content="9.80" />
      <meta itemprop="priceCurrency" content="EUR" />
      <meta
        itemprop="description"
        content="Rundum-Sorglos – Deckungssumme 50 Mio. €, keine Selbstbeteiligung"
      />
    </div>
    <dxp-tariff-comparison
      headline={TARIFF.headline}
      sub-headline={TARIFF.subHeadline}
      tariffs={TARIFF.data}></dxp-tariff-comparison>
  </div>

  <TrapCrossSell />

  <p
    style="margin-top: 2rem; padding: 1rem; background: #f0f0f0; border-left: 4px solid #4a5dc9;"
  >
    <a href={FOOTER_LINK.href}>{FOOTER_LINK.text}</a>
  </p>
</BaseLayout>
