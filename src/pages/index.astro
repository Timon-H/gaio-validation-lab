---
import BaseLayout from '../layouts/BaseLayout.astro';

const homeSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "GAIO Validation Lab",
  "description": "Testing environment for web components to validate Gen-AI optimization methods",
  "url": "https://gaio-validation-lab.vercel.app"
};
---

<BaseLayout 
  title="GAIO Validation Lab"
  description="Testing environment for web components to validate Gen-AI optimization methods"
  group="B"
  schemaData={homeSchema}
>
  <div style="margin-top: 1.5rem;">
    <h2>Welcome to GAIO Validation Lab</h2>
    <p>
      A minimalist environment to validate and benchmark 
      generative AI optimization approaches on web components.
    </p>
    
    <h3>Multi-Arm Test Design</h3>
    <p>7 variants of the same page content — each isolates a single GAIO variable for scientific measurement.</p>

    <div style="display: grid; gap: 1rem; margin-top: 1rem;">
      <div style="padding: 1rem; border: 2px solid #d32f2f; border-radius: 8px;">
        <h4 style="color: #d32f2f; margin-top: 0;">Baseline — Control Group A</h4>
        <p>Standard DXP components with Shadow DOM. No GAIO measures. <strong>Poor GAIObility.</strong></p>
        <a href="/control-group-a" style="color: #d32f2f; font-weight: bold;">View Baseline →</a>
      </div>

      <div style="padding: 1rem; border: 2px solid #43a047; border-radius: 8px;">
        <h4 style="color: #43a047; margin-top: 0;">Full Combo — Test Group B</h4>
        <p>All GAIO measures combined: JSON-LD + Semantic HTML + ARIA + &lt;noscript&gt; fallbacks.</p>
        <a href="/test-group-b" style="color: #43a047; font-weight: bold;">View Full Combo →</a>
      </div>
    </div>

    <h3 style="margin-top: 2rem;">Isolated Variables</h3>
    <p>Each page applies <strong>exactly one</strong> GAIO measure to the same components:</p>

    <div style="display: grid; gap: 0.75rem; margin-top: 1rem;">
      <div style="padding: 0.75rem 1rem; border-left: 4px solid #ff9800; background: #fff8e1; border-radius: 4px;">
        <strong>JSON-LD Only</strong> — Structured data in &lt;head&gt;, no other changes.
        <a href="/test-jsonld-only" style="color: #ff9800; margin-left: 1rem;">View →</a>
      </div>
      <div style="padding: 0.75rem 1rem; border-left: 4px solid #3f51b5; background: #e8eaf6; border-radius: 4px;">
        <strong>Semantic HTML Only</strong> — &lt;section&gt;, &lt;article&gt; wrappers, no other changes.
        <a href="/test-semantic-only" style="color: #3f51b5; margin-left: 1rem;">View →</a>
      </div>
      <div style="padding: 0.75rem 1rem; border-left: 4px solid #e91e63; background: #fce4ec; border-radius: 4px;">
        <strong>&lt;noscript&gt; Fallbacks Only</strong> — Light DOM content for no-JS crawlers.
        <a href="/test-noscript-only" style="color: #e91e63; margin-left: 1rem;">View →</a>
      </div>
      <div style="padding: 0.75rem 1rem; border-left: 4px solid #009688; background: #e0f2f1; border-radius: 4px;">
        <strong>ARIA Only</strong> — aria-label/aria-labelledby on host elements.
        <a href="/test-aria-only" style="color: #009688; margin-left: 1rem;">View →</a>
      </div>
      <div style="padding: 0.75rem 1rem; border-left: 4px solid #9c27b0; background: #f3e5f5; border-radius: 4px;">
        <strong>Declarative Shadow DOM</strong> — Server-rendered shadow content, no JavaScript.
        <a href="/test-dsd" style="color: #9c27b0; margin-left: 1rem;">View →</a>
      </div>
    </div>

    <h3 style="margin-top: 2rem;">Methodology</h3>
    <p>
      The same insurance content (FAQ, tariff comparison, form fields, product cards) appears on every page.
      Only the <em>delivery mechanism</em> changes. The middleware logs which AI crawlers visit each variant,
      and the content extraction script measures what content each crawler can actually parse.
    </p>
  </div>
</BaseLayout>
