---
/**
 * Isolated Test: ARIA Attributes Only
 * 
 * Same components as Baseline (Shadow DOM, <div> wrappers, no JSON-LD, no <noscript>),
 * but WITH ARIA attributes (aria-label, aria-labelledby, role) on host elements.
 * 
 * Isolates the effect of ARIA on GAIObility — can crawlers/LLMs use
 * ARIA attributes on custom elements to understand their purpose?
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Isolated Test: ARIA Only"
  description="DXP components with ARIA attributes on host elements only – no JSON-LD, no semantic HTML, no noscript fallbacks."
>
  <script>
    import '../../components/baseline/index.ts';
  </script>

  <div style="margin-top: 1.5rem;">
    <h2>Isolated Variable: ARIA Attributes Only</h2>
    <p>
      Same components as <a href="/control">Baseline</a>, same <code>&lt;div&gt;</code> wrappers — 
      but with <strong>ARIA attributes</strong> on the custom element host nodes.
    </p>
    <p style="padding: 0.5rem; background: #e0f2f1; border-left: 3px solid #009688; font-size: 0.875rem;">
      <strong>Isolated variable:</strong> ARIA (aria-label, aria-labelledby, role). No JSON-LD, no semantic HTML, no &lt;noscript&gt; fallbacks.
    </p>
  </div>

  <!-- BUTTON -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Button</div>
    <dxp-button aria-label="Beitrag jetzt online berechnen">Jetzt berechnen</dxp-button>
    <dxp-button variant="secondary" aria-label="Mehr über unsere Versicherungsprodukte erfahren">Mehr erfahren</dxp-button>
    <dxp-button disabled aria-label="Derzeit nicht verfügbar">Nicht verfügbar</dxp-button>
  </div>

  <!-- TEXT INPUT -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Text Input</div>
    <div role="group" aria-label="Persönliche Daten eingeben">
      <dxp-text-input label="Vorname" name="vorname" placeholder="Max" required required-error-text="Bitte geben Sie Ihren Vornamen ein." aria-required="true"></dxp-text-input>
      <dxp-text-input label="E-Mail" name="email" type="email" placeholder="max@example.de" regex="^[^@]+@[^@]+\.[^@]+$" regex-error-text="Bitte geben Sie eine gültige E-Mail-Adresse ein."></dxp-text-input>
    </div>
  </div>

  <!-- ============================================ -->
  <!-- SLIDER: Deckungssumme — ARIA-Label vorhanden  -->
  <!-- ============================================ -->
  <div style="margin: 1rem 0 0.5rem;">
    <input type="range" min="100000" max="10000000" step="500000" value="5000000"
           aria-label="Gewünschte Deckungssumme in Euro"
           style="width: 100%; accent-color: #0066cc;">
  </div>

  <!-- DROPDOWN -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Dropdown</div>
    <dxp-dropdown-v1 label="Versicherungstyp" name="versicherungstyp" placeholder="Bitte wählen..." options='[{"key":"haftpflicht","value":"Haftpflichtversicherung"},{"key":"kasko","value":"Kaskoversicherung"},{"key":"teilkasko","value":"Teilkaskoversicherung"}]' required aria-label="Versicherungstyp auswählen: Haftpflicht, Kasko oder Teilkasko"></dxp-dropdown-v1>
  </div>

  <!-- RADIO -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Input Radio</div>
    <dxp-input-radio label="Zahlungsweise" name="zahlungsweise" options='[{"value":"monatlich","label":"Monatlich"},{"value":"quartal","label":"Vierteljährlich"},{"value":"jaehrlich","label":"Jährlich"}]' default="monatlich" aria-label="Zahlungsweise: Monatlich, Vierteljährlich oder Jährlich"></dxp-input-radio>
  </div>

  <!-- ============================================ -->
  <!-- GEBURTSJAHR — ARIA-Label vorhanden           -->
  <!-- ============================================ -->
  <div style="margin: 0.5rem 0 2rem;">
    <input type="text" name="geburtsjahr" inputmode="numeric" pattern="\d{4}" maxlength="4"
           aria-label="Geburtsjahr eingeben"
           style="border: 1px solid #ccc; padding: 0.4rem 0.6rem; border-radius: 4px; width: 120px;">
  </div>

  <!-- ACCORDION -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Accordion</div>
    <dxp-accordion aria-label="FAQ-Bereich mit 3 Fragen">
      <dxp-accordion-element id="faq-1" aria-label="Was ist eine Haftpflichtversicherung?">
        <span slot="headline">Was ist eine Haftpflichtversicherung?</span>
        <p>Eine Haftpflichtversicherung schützt Sie vor Schadensersatzansprüchen Dritter. Sie übernimmt die Kosten, wenn Sie versehentlich Schäden an Personen oder deren Eigentum verursachen.</p>
      </dxp-accordion-element>
      <dxp-accordion-element id="faq-2" aria-label="Wie berechne ich meinen Beitrag?">
        <span slot="headline">Wie berechne ich meinen Beitrag?</span>
        <p>Ihr Beitrag hängt von verschiedenen Faktoren ab, wie z.B. Ihrem Alter, Ihrem Wohnort und dem gewünschten Versicherungsschutz. Nutzen Sie unseren Online-Rechner für eine individuelle Berechnung.</p>
      </dxp-accordion-element>
      <dxp-accordion-element id="faq-3" aria-label="Kann ich meine Versicherung online kündigen?">
        <span slot="headline">Kann ich meine Versicherung online kündigen?</span>
        <p>Ja, Sie können Ihre Versicherung jederzeit online über Ihr Kundenkonto kündigen. Die Kündigungsfrist beträgt in der Regel einen Monat zum Ende der Vertragslaufzeit.</p>
      </dxp-accordion-element>
    </dxp-accordion>
  </div>

  <!-- CARD -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Card</div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem;">
      <dxp-card aria-label="Privathaftpflicht – ab 3,50 € monatlich, empfohlen">
        <span slot="badge" style="background: #e3f2fd; color: #0066cc;">Empfohlen</span>
        <h3 slot="header-title">Privathaftpflicht</h3>
        <p slot="teaser-text">Umfassender Schutz für Ihren Alltag – ab 3,50 € im Monat.</p>
        <dxp-button slot="buttons">Jetzt abschließen</dxp-button>
      </dxp-card>
      <dxp-card aria-label="Hausratversicherung – Schutz gegen Einbruch, Feuer und Wasserschäden">
        <h3 slot="header-title">Hausratversicherung</h3>
        <p slot="teaser-text">Schützen Sie Ihr Hab und Gut gegen Einbruch, Feuer und Wasserschäden.</p>
        <dxp-button slot="buttons" variant="secondary">Details ansehen</dxp-button>
      </dxp-card>
    </div>
  </div>

  <!-- FLYOUT -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Flyout</div>
    <dxp-flyout flyout-position="left" aria-label="Kontaktinformationen: Telefon 0800 123 456 789, Mo–Fr 8–18 Uhr">
      <dxp-button slot="content" variant="secondary">Hilfe & Kontakt</dxp-button>
      <div slot="flyout" style="padding: 0.5rem;">
        <p style="margin: 0 0 0.5rem;"><strong>Kundenservice</strong></p>
        <p style="margin: 0;">Telefon: 0800 123 456 789</p>
        <p style="margin: 0;">Mo–Fr: 8:00–18:00 Uhr</p>
      </div>
    </dxp-flyout>
  </div>

  <!-- TARIFF COMPARISON -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Tariff Comparison</div>
    <!-- Testimonial — Preis-Rauschen nahe Tarifbereich -->
    <p style="font-size: 0.875rem; color: #555; border-left: 3px solid #ddd; padding: 0.5rem 0.75rem; margin: 0.5rem 0;">
      <em>„Ich spare jetzt <strong>12 € pro Monat</strong> gegenüber meinem alten Anbieter – super Preis-Leistung!“</em><br>
      <small>– Kundin Lisa M., München</small>
    </p>
    <!-- Veralteter Tarif — kein semantischer Kontext -->
    <p style="font-size: 0.8rem; color: #aaa; margin-bottom: 0.75rem;">
      Unser früherer Einsteiger-Tarif war ab <strong>1,99 €</strong> / Monat erhältlich – dieser Tarif ist nicht mehr buchbar.
    </p>
    <dxp-tariff-comparison headline="Unsere Tarife im Vergleich" sub-headline="Wählen Sie den passenden Schutz für Ihre Bedürfnisse" aria-label="Tarifvergleich: Basis ab 3,50 €, Komfort ab 5,90 €, Premium ab 9,80 € monatlich" tariffs='{"prefix":"ab","productName":"Haftpflicht","suffix":"€","tariffData":[{"id":"basis","name":"Basis","period":"monthly","premium":"3,50","description":"Grundschutz","buttons":[{"label":"Auswählen"}],"moduleConfigs":[{"moduleReference":"deckung","moduleReferenceUuid":"1","value":{"selectedText":"5 Mio. €"}},{"moduleReference":"selbstbeteiligung","moduleReferenceUuid":"2","value":{"selectedText":"150 €"}}]},{"id":"komfort","name":"Komfort","period":"monthly","premium":"5,90","highlighted":true,"overline":"Beliebteste Wahl","description":"Erweiterter Schutz","buttons":[{"label":"Auswählen"}],"moduleConfigs":[{"moduleReference":"deckung","moduleReferenceUuid":"1","value":{"selectedText":"10 Mio. €"}},{"moduleReference":"selbstbeteiligung","moduleReferenceUuid":"2","value":{"selectedText":"0 €"}}]},{"id":"premium","name":"Premium","period":"monthly","premium":"9,80","description":"Rundum-Sorglos","buttons":[{"label":"Auswählen"}],"moduleConfigs":[{"moduleReference":"deckung","moduleReferenceUuid":"1","value":{"selectedText":"50 Mio. €"}},{"moduleReference":"selbstbeteiligung","moduleReferenceUuid":"2","value":{"selectedText":"0 €"}}]}],"moduleGroups":[{"name":"Leistungen","modules":[{"moduleName":"deckung","name":"Deckungssumme","uuid":"1"},{"moduleName":"selbstbeteiligung","name":"Selbstbeteiligung","uuid":"2"}]}]}'></dxp-tariff-comparison>
  </div>

  <!-- ============================================ -->
  <!-- CROSS-SELL — kein semantischer Kontext (<div>)-->
  <!-- ============================================ -->
  <div style="margin: 2rem 0; padding: 1rem; background: #f9f9f9; border: 1px dashed #bbb; border-radius: 4px;">
    <p style="margin: 0 0 0.5rem; font-weight: 600; font-size: 0.875rem; color: #555;">Das könnte Sie auch interessieren</p>
    <p style="margin: 0 0 0.5rem;">Kombinieren Sie Ihren Schutz – <strong>KFZ-Haftpflicht</strong> bereits ab <strong>39,00 €</strong> monatlich verfügbar.</p>
    <ul style="margin: 0.25rem 0 0; padding-left: 1.5rem; font-size: 0.875rem;">
      <li>KFZ Basis – 39,00 € / Monat · Selbstbeteiligung: 500 €</li>
      <li>KFZ Komfort – 59,00 € / Monat · Selbstbeteiligung: 0 €</li>
    </ul>
  </div>

  <p style="margin-top: 2rem; padding: 1rem; background: #f0f0f0; border-left: 4px solid #009688;">
    <a href="/control">← Baseline (keine Maßnahmen)</a> · 
    <a href="/combined">Alle Maßnahmen kombiniert →</a>
  </p>
</BaseLayout>
