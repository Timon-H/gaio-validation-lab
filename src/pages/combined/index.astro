---
/**
 * Combined — GAIO-Optimized Components (Full Combo)
 *
 * The SAME web components as Baseline, but with ALL GAIO countermeasures:
 * - JSON-LD structured data describing each component's content
 * - Semantic HTML wrappers (<section>, <article>) around every component
 * - ARIA attributes on host elements for additional context
 * - Declarative Shadow DOM via @lit-labs/ssr (shadow content in initial HTML)
 * - robots meta + canonical URL for optimal crawler directives
 *
 * NOTE: <noscript> fallbacks are NOT included here because DSD makes them
 * redundant — the shadow content is already in the initial HTML without JS.
 * The noscript technique is tested in isolation at /test-noscript.
 *
 * Crawlers and LLMs can now parse the page content even though the
 * interactive rendering still lives inside Shadow DOM.
 * DSD supersedes <noscript> as a content accessibility mechanism.
 */
import { renderLitToString, html } from "../../lib/lit-ssr.ts";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  TrapAriaHiddenBonus,
  TrapBirthYear,
  TrapCoverageAmount,
  TrapCrossSell,
  TrapDeprecatedTariff,
  TrapTestimonial,
} from "../../components/traps/index.ts";
import {
  PAGE_TITLE,
  PAGE_DESCRIPTION,
  INTRO,
  BUTTONS,
  TEXT_INPUTS,
  DROPDOWN,
  RADIO,
  FAQS,
  TRAP_FAQ,
  CARDS,
  FLYOUT,
  TARIFF,
  FOOTER_LINK,
  SECTION_HEADINGS,
  ARIA_LABELS,
  buildGaioSchema,
} from "../../data/content";

// Import all component side-effects (registers custom elements for SSR)
import "../../components/baseline/dxp-button.ts";
import "../../components/baseline/dxp-text-input.ts";
import "../../components/baseline/dxp-dropdown.ts";
import "../../components/baseline/dxp-input-radio.ts";
import "../../components/baseline/dxp-accordion.ts";
import "../../components/baseline/dxp-accordion-element.ts";
import "../../components/baseline/dxp-card.ts";
import "../../components/baseline/dxp-flyout.ts";
import "../../components/baseline/dxp-tariff-comparison.ts";

const gaioSchema = buildGaioSchema();

// Server-render each component section to DSD HTML strings
const buttonHtml = await renderLitToString(html`
  <dxp-button aria-label=${ARIA_LABELS.buttonPrimary}
    >${BUTTONS.primary}</dxp-button
  >
  <dxp-button variant="secondary" aria-label=${ARIA_LABELS.buttonSecondary}
    >${BUTTONS.secondary}</dxp-button
  >
  <dxp-button disabled aria-label=${ARIA_LABELS.buttonDisabled}
    >${BUTTONS.disabled}</dxp-button
  >
`);

const textInputHtml = await renderLitToString(html`
  <dxp-text-input
    label=${TEXT_INPUTS.vorname.label}
    name=${TEXT_INPUTS.vorname.name}
    placeholder=${TEXT_INPUTS.vorname.placeholder}
    required
    required-error-text=${TEXT_INPUTS.vorname.requiredErrorText}
    aria-required="true"
  ></dxp-text-input>
  <dxp-text-input
    label=${TEXT_INPUTS.email.label}
    name=${TEXT_INPUTS.email.name}
    type=${TEXT_INPUTS.email.type}
    placeholder=${TEXT_INPUTS.email.placeholder}
    regex=${TEXT_INPUTS.email.regex}
    regex-error-text=${TEXT_INPUTS.email.regexErrorText}
  ></dxp-text-input>
`);

const dropdownHtml = await renderLitToString(html`
  <dxp-dropdown-v1
    label=${DROPDOWN.label}
    name=${DROPDOWN.name}
    placeholder=${DROPDOWN.placeholder}
    options=${DROPDOWN.options}
    required
    aria-label=${ARIA_LABELS.dropdown}
  ></dxp-dropdown-v1>
`);

const radioHtml = await renderLitToString(html`
  <dxp-input-radio
    label=${RADIO.label}
    name=${RADIO.name}
    options=${RADIO.options}
    default=${RADIO.default}
    aria-label=${ARIA_LABELS.radio}
  ></dxp-input-radio>
`);

const accordionHtml = await renderLitToString(html`
  <dxp-accordion aria-label=${ARIA_LABELS.accordion}>
    ${FAQS.map(
      (faq) => html`
        <dxp-accordion-element
          id=${faq.id}
          aria-label=${faq.headline}
          headline=${faq.headline}
          body=${faq.body}
        ></dxp-accordion-element>
      `,
    )}
    <!-- Trap 7 (TrapHiddenFaq) inlined here because Lit SSR requires template literals;
         the Astro component version is used on all non-SSR pages. -->
    <dxp-accordion-element
      id=${TRAP_FAQ.id}
      aria-hidden="true"
      headline=${TRAP_FAQ.headline}
      body=${TRAP_FAQ.body}
    ></dxp-accordion-element>
  </dxp-accordion>
`);

const cardHtml1 = await renderLitToString(html`
  <dxp-card
    aria-label=${ARIA_LABELS.card1}
    card-title=${CARDS[0].title}
    card-description=${CARDS[0].description}
  >
    <span slot="badge" style="background: #e3f2fd; color: #0066cc;"
      >${CARDS[0].badge}</span
    >
    <dxp-button slot="buttons">${CARDS[0].button}</dxp-button>
  </dxp-card>
`);

const cardHtml2 = await renderLitToString(html`
  <dxp-card
    aria-label=${ARIA_LABELS.card2}
    card-title=${CARDS[1].title}
    card-description=${CARDS[1].description}
  >
    <dxp-button slot="buttons" variant="secondary"
      >${CARDS[1].button}</dxp-button
    >
  </dxp-card>
`);

const flyoutHtml = await renderLitToString(html`
  <dxp-flyout
    flyout-position=${FLYOUT.position}
    aria-label=${ARIA_LABELS.flyout}
    phone=${FLYOUT.phone}
    hours=${FLYOUT.hours}
  >
    <dxp-button slot="content" variant="secondary">${FLYOUT.button}</dxp-button>
  </dxp-flyout>
`);

const tariffHtml = await renderLitToString(html`
  <dxp-tariff-comparison
    headline=${TARIFF.headline}
    sub-headline=${TARIFF.subHeadline}
    aria-label=${ARIA_LABELS.tariff}
    tariffs=${TARIFF.data}
  ></dxp-tariff-comparison>
`);
---

<BaseLayout
  title={PAGE_TITLE}
  description={PAGE_DESCRIPTION}
  schemaData={gaioSchema}
>
  <!-- SSR-only: hydration intentionally omitted to avoid duplicate late client rendering. -->

  <section aria-labelledby="page-heading" style="margin-top: 1.5rem;">
    <h2 id="page-heading">{INTRO.heading}</h2>
    <p>{INTRO.description}</p>
  </section>

  <!-- BUTTON — DSD + Semantic + ARIA -->
  <section aria-label="Call-to-Action Buttons" style="margin: 2rem 0;">
    <h3>{SECTION_HEADINGS.buttons.heading}</h3>
    <p>{SECTION_HEADINGS.buttons.description}</p>
    <Fragment set:html={buttonHtml} />
  </section>

  <!-- TEXT INPUT — DSD + Semantic + ARIA + Microdata -->
  <section
    aria-label="Kontaktformular"
    style="margin: 2rem 0;"
    itemscope
    itemtype="https://schema.org/Person"
  >
    <meta
      itemprop="description"
      content="Persönliche Angaben: Vorname und E-Mail-Adresse für ein individuelles Versicherungsangebot"
    />
    <h3>{SECTION_HEADINGS.textInputs.heading}</h3>
    <p>{SECTION_HEADINGS.textInputs.description}</p>
    <div role="group" aria-label="Ihre Daten">
      <Fragment set:html={textInputHtml} />
    </div>
  </section>

  <TrapCoverageAmount aria />

  <!-- DROPDOWN — DSD + Semantic + ARIA + Microdata -->
  <section
    aria-label="Versicherungsauswahl"
    style="margin: 2rem 0;"
    itemscope
    itemtype="https://schema.org/ItemList"
  >
    <meta itemprop="name" content="Versicherungstyp" />
    <h3>{SECTION_HEADINGS.dropdown.heading}</h3>
    <p>{SECTION_HEADINGS.dropdown.description}</p>
    <Fragment set:html={dropdownHtml} />
  </section>

  <!-- RADIO — DSD + Semantic + ARIA + Microdata -->
  <section
    aria-label="Zahlungsoptionen"
    style="margin: 2rem 0;"
    itemscope
    itemtype="https://schema.org/ItemList"
  >
    <meta itemprop="name" content="Zahlungsweise" />
    <h3>{SECTION_HEADINGS.radio.heading}</h3>
    <p>{SECTION_HEADINGS.radio.description}</p>
    <Fragment set:html={radioHtml} />
  </section>

  <TrapBirthYear aria />

  <!-- ACCORDION / FAQ — DSD + Semantic + ARIA + Microdata -->
  <section
    aria-labelledby="faq-heading"
    style="margin: 2rem 0;"
    itemscope
    itemtype="https://schema.org/FAQPage"
  >
    <h3 id="faq-heading">{SECTION_HEADINGS.accordion.heading}</h3>
    <p>{SECTION_HEADINGS.accordion.description}</p>
    <Fragment set:html={accordionHtml} />
  </section>

  <!-- CARD — DSD + Semantic + ARIA -->
  <section aria-labelledby="products-heading" style="margin: 2rem 0;">
    <h3 id="products-heading">{SECTION_HEADINGS.cards.heading}</h3>
    <p>{SECTION_HEADINGS.cards.description}</p>
    <div
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem;"
    >
      <article
        aria-label="Privathaftpflicht – ab 3,50 € monatlich"
        itemscope
        itemtype="https://schema.org/Product"
      >
        <meta itemprop="name" content="Privathaftpflicht" />
        <meta
          itemprop="description"
          content="Umfassender Schutz für Ihren Alltag – ab 3,50 € im Monat."
        />
        <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <meta itemprop="price" content="3.50" />
          <meta itemprop="priceCurrency" content="EUR" />
        </div>
        <Fragment set:html={cardHtml1} />
      </article>
      <article
        aria-label="Hausratversicherung – Schutz für Hab und Gut"
        itemscope
        itemtype="https://schema.org/Product"
      >
        <meta itemprop="name" content="Hausratversicherung" />
        <meta
          itemprop="description"
          content="Schützen Sie Ihr Hab und Gut gegen Einbruch, Feuer und Wasserschäden."
        />
        <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <meta itemprop="price" content="4.20" />
          <meta itemprop="priceCurrency" content="EUR" />
        </div>
        <Fragment set:html={cardHtml2} />
      </article>
    </div>
  </section>

  <!-- FLYOUT — DSD + Semantic + ARIA -->
  <section aria-label="Hilfe und Kontakt" style="margin: 2rem 0;">
    <h3>{SECTION_HEADINGS.flyout.heading}</h3>
    <p>{SECTION_HEADINGS.flyout.description}</p>
    <Fragment set:html={flyoutHtml} />
  </section>

  <!-- TARIFF COMPARISON — DSD + Semantic + ARIA -->
  <section
    aria-labelledby="tariff-heading"
    style="margin: 2rem 0;"
    itemscope
    itemtype="https://schema.org/WebPage"
  >
    <meta itemprop="name" content="Haftpflichtversicherung – Tarifvergleich" />
    <h3 id="tariff-heading">{SECTION_HEADINGS.tariff.heading}</h3>
    <p>{SECTION_HEADINGS.tariff.description}</p>
    <TrapTestimonial semantic />
    <TrapDeprecatedTariff semantic />
    <TrapAriaHiddenBonus aria semantic />
    <Fragment set:html={tariffHtml} />
  </section>

  <TrapCrossSell semantic />

  <aside
    style="margin-top: 2rem; padding: 1rem; background: #f0f0f0; border-left: 4px solid #4a5dc9;"
  >
    <a href={FOOTER_LINK.href}>{FOOTER_LINK.text}</a>
  </aside>
</BaseLayout>
