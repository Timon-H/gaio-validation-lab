---
/**
 * Isolated Test: <noscript> Light DOM Fallbacks Only
 *
 * Same components as Baseline (Shadow DOM, <div> wrappers, no JSON-LD, no ARIA),
 * but WITH <noscript> blocks providing Light DOM content for each component.
 *
 * Isolates the effect of Light DOM fallbacks on AI extractability.
 * Crawlers that don't execute JS will see the fallback content.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  TrapAriaHiddenBonus,
  TrapBirthYear,
  TrapCoverageAmount,
  TrapCrossSell,
  TrapDeprecatedTariff,
  TrapHiddenFaq,
  TrapTestimonial,
} from "../../components/traps/index.ts";
import {
  PAGE_TITLE,
  PAGE_DESCRIPTION,
  INTRO,
  BUTTONS,
  TEXT_INPUTS,
  DROPDOWN,
  RADIO,
  FAQS,
  CARDS,
  FLYOUT,
  TARIFF,
  FOOTER_LINK,
} from "../../data/content";
---

<BaseLayout title={PAGE_TITLE} description={PAGE_DESCRIPTION}>
  <script>
    import "../../components/baseline/index.ts";
  </script>

  <div style="margin-top: 1.5rem;">
    <h2>{INTRO.heading}</h2>
    <p>{INTRO.description}</p>
  </div>

  <!-- BUTTON -->
  <div style="margin: 2rem 0;">
    <dxp-button>{BUTTONS.primary}</dxp-button>
    <dxp-button variant="secondary">{BUTTONS.secondary}</dxp-button>
    <dxp-button disabled>{BUTTONS.disabled}</dxp-button>
    <noscript>
      <ul>
        <li><a href="/berechnen">Jetzt berechnen</a></li>
        <li><a href="/produkte">Mehr erfahren</a></li>
      </ul>
    </noscript>
  </div>

  <!-- TEXT INPUT -->
  <div style="margin: 2rem 0;">
    <dxp-text-input
      label={TEXT_INPUTS.vorname.label}
      name={TEXT_INPUTS.vorname.name}
      placeholder={TEXT_INPUTS.vorname.placeholder}
      required
      required-error-text={TEXT_INPUTS.vorname.requiredErrorText}
    ></dxp-text-input>
    <dxp-text-input
      label={TEXT_INPUTS.email.label}
      name={TEXT_INPUTS.email.name}
      type={TEXT_INPUTS.email.type}
      placeholder={TEXT_INPUTS.email.placeholder}
      regex={TEXT_INPUTS.email.regex}
      regex-error-text={TEXT_INPUTS.email.regexErrorText}></dxp-text-input>
    <noscript>
      <form>
        <label for="fallback-vorname">Vorname (Pflichtfeld)</label>
        <input id="fallback-vorname" name="vorname" type="text" required />
        <label for="fallback-email">E-Mail</label>
        <input id="fallback-email" name="email" type="email" />
      </form>
    </noscript>
  </div>

  <TrapCoverageAmount />

  <!-- DROPDOWN -->
  <div style="margin: 2rem 0;">
    <dxp-dropdown-v1
      label={DROPDOWN.label}
      name={DROPDOWN.name}
      placeholder={DROPDOWN.placeholder}
      options={DROPDOWN.options}
      required></dxp-dropdown-v1>
    <noscript>
      <label for="fallback-versicherung">Versicherungstyp</label>
      <select id="fallback-versicherung" name="versicherungstyp">
        <option value="">Bitte wählen...</option>
        <option value="haftpflicht">Haftpflichtversicherung</option>
        <option value="kasko">Kaskoversicherung</option>
        <option value="teilkasko">Teilkaskoversicherung</option>
      </select>
    </noscript>
  </div>

  <!-- RADIO -->
  <div style="margin: 2rem 0;">
    <dxp-input-radio
      label={RADIO.label}
      name={RADIO.name}
      options={RADIO.options}
      default={RADIO.default}></dxp-input-radio>
    <noscript>
      <fieldset>
        <legend>Zahlungsweise</legend>
        <label
          ><input type="radio" name="zahlungsweise" value="monatlich" checked /> Monatlich</label
        >
        <label
          ><input type="radio" name="zahlungsweise" value="quartal" /> Vierteljährlich</label
        >
        <label
          ><input type="radio" name="zahlungsweise" value="jaehrlich" /> Jährlich</label
        >
      </fieldset>
    </noscript>
  </div>

  <TrapBirthYear noscript />

  <!-- ACCORDION -->
  <div style="margin: 2rem 0;">
    <dxp-accordion>
      {
        FAQS.map((faq) => (
          <dxp-accordion-element
            id={faq.id}
            headline={faq.headline}
            body={faq.body}
          />
        ))
      }
      <TrapHiddenFaq noscript />
    </dxp-accordion>
    <noscript>
      <dl>
        <dt>Was ist eine Haftpflichtversicherung?</dt>
        <dd>
          Eine Haftpflichtversicherung schützt Sie vor Schadensersatzansprüchen
          Dritter. Sie übernimmt die Kosten, wenn Sie versehentlich Schäden an
          Personen oder deren Eigentum verursachen.
        </dd>
        <dt>Wie berechne ich meinen Beitrag?</dt>
        <dd>
          Ihr Beitrag hängt von verschiedenen Faktoren ab, wie z.B. Ihrem Alter,
          Ihrem Wohnort und dem gewünschten Versicherungsschutz. Nutzen Sie
          unseren Online-Rechner für eine individuelle Berechnung.
        </dd>
        <dt>Kann ich meine Versicherung online kündigen?</dt>
        <dd>
          Ja, Sie können Ihre Versicherung jederzeit online über Ihr Kundenkonto
          kündigen. Die Kündigungsfrist beträgt in der Regel einen Monat zum
          Ende der Vertragslaufzeit.
        </dd>
      </dl>
    </noscript>
  </div>

  <!-- CARD -->
  <div style="margin: 2rem 0;">
    <div
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem;"
    >
      <div>
        <dxp-card
          card-title={CARDS[0].title}
          card-description={CARDS[0].description}
        >
          <span slot="badge" style="background: #e3f2fd; color: #0066cc;"
            >{CARDS[0].badge}</span
          >
          <dxp-button slot="buttons">{CARDS[0].button}</dxp-button>
        </dxp-card>
        <noscript>
          <h4>Privathaftpflicht</h4>
          <p>
            Umfassender Schutz für Ihren Alltag – ab 3,50 € im Monat. <a
              href="/produkte/haftpflicht">Jetzt abschließen</a
            >
          </p>
        </noscript>
      </div>
      <div>
        <dxp-card
          card-title={CARDS[1].title}
          card-description={CARDS[1].description}
        >
          <dxp-button slot="buttons" variant="secondary"
            >{CARDS[1].button}</dxp-button
          >
        </dxp-card>
        <noscript>
          <h4>Hausratversicherung</h4>
          <p>
            Schützen Sie Ihr Hab und Gut gegen Einbruch, Feuer und
            Wasserschäden. <a href="/produkte/hausrat">Details ansehen</a>
          </p>
        </noscript>
      </div>
    </div>
  </div>

  <!-- FLYOUT -->
  <div style="margin: 2rem 0;">
    <dxp-flyout
      flyout-position={FLYOUT.position}
      phone={FLYOUT.phone}
      hours={FLYOUT.hours}
    >
      <dxp-button slot="content" variant="secondary">{FLYOUT.button}</dxp-button
      >
    </dxp-flyout>
    <noscript>
      <address>
        <strong>Kundenservice</strong><br />
        Telefon: <a href="tel:+498001234567890">0800 123 456 789</a><br />
        Erreichbar Mo–Fr: 8:00–18:00 Uhr
      </address>
    </noscript>
  </div>

  <!-- TARIFF COMPARISON -->
  <div style="margin: 2rem 0;">
    <TrapTestimonial />
    <TrapDeprecatedTariff />
    <TrapAriaHiddenBonus />
    <dxp-tariff-comparison
      headline={TARIFF.headline}
      sub-headline={TARIFF.subHeadline}
      tariffs={TARIFF.data}></dxp-tariff-comparison>
    <noscript>
      <table>
        <caption>Haftpflichtversicherung – Tarifvergleich</caption>
        <thead>
          <tr
            ><th>Tarif</th><th>Monatsbeitrag</th><th>Deckungssumme</th><th
              >Selbstbeteiligung</th
            ></tr
          >
        </thead>
        <tbody>
          <tr
            ><td>Basis</td><td>ab 3,50 €</td><td>5 Mio. €</td><td>150 €</td></tr
          >
          <tr
            ><td>Komfort (Beliebteste Wahl)</td><td>ab 5,90 €</td><td
              >10 Mio. €</td
            ><td>0 €</td></tr
          >
          <tr
            ><td>Premium</td><td>ab 9,80 €</td><td>50 Mio. €</td><td>0 €</td
            ></tr
          >
        </tbody>
      </table>
    </noscript>
  </div>

  <TrapCrossSell />

  <p
    style="margin-top: 2rem; padding: 1rem; background: #f0f0f0; border-left: 4px solid #4a5dc9;"
  >
    <a href={FOOTER_LINK.href}>{FOOTER_LINK.text}</a>
  </p>
</BaseLayout>
