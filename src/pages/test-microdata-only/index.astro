---
/**
 * Isolated Test: Microdata Only
 * 
 * Same components as Baseline (Shadow DOM, <div> wrappers, no JSON-LD, no ARIA),
 * but WITH Microdata attributes (itemscope, itemtype, itemprop) on wrapper elements.
 * 
 * Isolates the effect of inline structured data (Microdata) on GAIObility.
 * Unlike JSON-LD (separate script block in head), Microdata weaves schema.org
 * annotations directly into the HTML markup.
 * 
 * This enables a direct comparison: same vocabulary (schema.org),
 * different delivery mechanism (inline attributes vs. JSON blob).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Isolated Test: Microdata Only"
  description="DXP components with schema.org Microdata attributes only – no JSON-LD, no semantic HTML, no ARIA, no noscript fallbacks."
>
  <script>
    import '../../components/baseline/index.ts';
  </script>

  <div style="margin-top: 1.5rem;">
    <h2>Isolated Variable: Microdata Only</h2>
    <p>
      Same components as <a href="/control">Baseline</a>, same <code>&lt;div&gt;</code> wrappers — 
      but with <strong>schema.org Microdata</strong> (<code>itemscope</code>, <code>itemtype</code>, <code>itemprop</code>) 
      woven into the HTML markup.
    </p>
    <p style="padding: 0.5rem; background: #f3e5f5; border-left: 3px solid #9c27b0; font-size: 0.875rem;">
      <strong>Isolated variable:</strong> Microdata (inline schema.org attributes). 
      No JSON-LD, no semantic HTML, no ARIA, no &lt;noscript&gt; fallbacks.
    </p>
  </div>

  <!-- BUTTON -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Button</div>
    <dxp-button>Jetzt berechnen</dxp-button>
    <dxp-button variant="secondary">Mehr erfahren</dxp-button>
    <dxp-button disabled>Nicht verfügbar</dxp-button>
  </div>

  <!-- TEXT INPUT — annotated as ContactPoint expectations -->
  <div style="margin: 2rem 0;" itemscope itemtype="https://schema.org/Person">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Text Input</div>
    <meta itemprop="description" content="Persönliche Angaben: Vorname und E-Mail-Adresse für ein individuelles Versicherungsangebot" />
    <dxp-text-input label="Vorname" name="vorname" placeholder="Max" required required-error-text="Bitte geben Sie Ihren Vornamen ein."></dxp-text-input>
    <dxp-text-input label="E-Mail" name="email" type="email" placeholder="max@example.de" regex="^[^@]+@[^@]+\.[^@]+$" regex-error-text="Bitte geben Sie eine gültige E-Mail-Adresse ein."></dxp-text-input>
  </div>

  <!-- ============================================ -->
  <!-- SLIDER: Deckungssumme — kein ARIA-Label       -->
  <!-- ============================================ -->
  <div style="margin: 1rem 0 0.5rem;">
    <input type="range" min="100000" max="10000000" step="500000" value="5000000"
           style="width: 100%; accent-color: #0066cc;">
  </div>

  <!-- DROPDOWN — annotated with product category -->
  <div style="margin: 2rem 0;" itemscope itemtype="https://schema.org/ItemList">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Dropdown</div>
    <meta itemprop="name" content="Versicherungstyp" />
    <meta itemprop="description" content="Auswahl der Versicherungsart: Haftpflicht-, Kasko- oder Teilkaskoversicherung" />
    <div itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <meta itemprop="position" content="1" /><meta itemprop="name" content="Haftpflichtversicherung" />
    </div>
    <div itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <meta itemprop="position" content="2" /><meta itemprop="name" content="Kaskoversicherung" />
    </div>
    <div itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <meta itemprop="position" content="3" /><meta itemprop="name" content="Teilkaskoversicherung" />
    </div>
    <dxp-dropdown-v1 label="Versicherungstyp" name="versicherungstyp" placeholder="Bitte wählen..." options='[{"key":"haftpflicht","value":"Haftpflichtversicherung"},{"key":"kasko","value":"Kaskoversicherung"},{"key":"teilkasko","value":"Teilkaskoversicherung"}]' required></dxp-dropdown-v1>
  </div>

  <!-- RADIO — annotated with payment frequency options -->
  <div style="margin: 2rem 0;" itemscope itemtype="https://schema.org/ItemList">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Input Radio</div>
    <meta itemprop="name" content="Zahlungsweise" />
    <meta itemprop="description" content="Zahlungsfrequenz für den Versicherungsbeitrag" />
    <div itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <meta itemprop="position" content="1" /><meta itemprop="name" content="Monatlich" />
    </div>
    <div itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <meta itemprop="position" content="2" /><meta itemprop="name" content="Vierteljährlich" />
    </div>
    <div itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <meta itemprop="position" content="3" /><meta itemprop="name" content="Jährlich" />
    </div>
    <dxp-input-radio label="Zahlungsweise" name="zahlungsweise" options='[{"value":"monatlich","label":"Monatlich"},{"value":"quartal","label":"Vierteljährlich"},{"value":"jaehrlich","label":"Jährlich"}]' default="monatlich"></dxp-input-radio>
  </div>

  <!-- ============================================ -->
  <!-- GEBURTSJAHR — Label nur via CSS, kein HTML-Label -->
  <!-- ============================================ -->
  <style>
    .field-geburtsjahr::before {
      content: "Geburtsjahr";
      display: block;
      font-size: 0.875rem;
      font-weight: 600;
      color: #333;
      margin-bottom: 0.25rem;
    }
  </style>
  <div class="field-geburtsjahr" style="margin: 0.5rem 0 2rem;">
    <input type="text" name="geburtsjahr" inputmode="numeric" pattern="\d{4}" maxlength="4"
           style="border: 1px solid #ccc; padding: 0.4rem 0.6rem; border-radius: 4px; width: 120px;">
  </div>

  <!-- ACCORDION / FAQ — annotated as FAQPage -->
  <div style="margin: 2rem 0;" itemscope itemtype="https://schema.org/FAQPage">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Accordion</div>
    <div itemprop="mainEntity" itemscope itemtype="https://schema.org/Question">
      <meta itemprop="name" content="Was ist eine Haftpflichtversicherung?" />
      <div itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
        <meta itemprop="text" content="Eine Haftpflichtversicherung schützt Sie vor Schadensersatzansprüchen Dritter. Sie übernimmt die Kosten, wenn Sie versehentlich Schäden an Personen oder deren Eigentum verursachen." />
      </div>
    </div>
    <div itemprop="mainEntity" itemscope itemtype="https://schema.org/Question">
      <meta itemprop="name" content="Wie berechne ich meinen Beitrag?" />
      <div itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
        <meta itemprop="text" content="Ihr Beitrag hängt von verschiedenen Faktoren ab, wie z.B. Ihrem Alter, Ihrem Wohnort und dem gewünschten Versicherungsschutz. Nutzen Sie unseren Online-Rechner für eine individuelle Berechnung." />
      </div>
    </div>
    <div itemprop="mainEntity" itemscope itemtype="https://schema.org/Question">
      <meta itemprop="name" content="Kann ich meine Versicherung online kündigen?" />
      <div itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
        <meta itemprop="text" content="Ja, Sie können Ihre Versicherung jederzeit online über Ihr Kundenkonto kündigen. Die Kündigungsfrist beträgt in der Regel einen Monat zum Ende der Vertragslaufzeit." />
      </div>
    </div>
    <dxp-accordion>
      <dxp-accordion-element id="faq-1">
        <span slot="headline">Was ist eine Haftpflichtversicherung?</span>
        <p>Eine Haftpflichtversicherung schützt Sie vor Schadensersatzansprüchen Dritter. Sie übernimmt die Kosten, wenn Sie versehentlich Schäden an Personen oder deren Eigentum verursachen.</p>
      </dxp-accordion-element>
      <dxp-accordion-element id="faq-2">
        <span slot="headline">Wie berechne ich meinen Beitrag?</span>
        <p>Ihr Beitrag hängt von verschiedenen Faktoren ab, wie z.B. Ihrem Alter, Ihrem Wohnort und dem gewünschten Versicherungsschutz. Nutzen Sie unseren Online-Rechner für eine individuelle Berechnung.</p>
      </dxp-accordion-element>
      <dxp-accordion-element id="faq-3">
        <span slot="headline">Kann ich meine Versicherung online kündigen?</span>
        <p>Ja, Sie können Ihre Versicherung jederzeit online über Ihr Kundenkonto kündigen. Die Kündigungsfrist beträgt in der Regel einen Monat zum Ende der Vertragslaufzeit.</p>
      </dxp-accordion-element>
    </dxp-accordion>
  </div>

  <!-- CARD — annotated as Product/Offer -->
  <div style="margin: 2rem 0;">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Card</div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem;">
      <div itemscope itemtype="https://schema.org/Product">
        <meta itemprop="name" content="Privathaftpflicht" />
        <meta itemprop="description" content="Umfassender Schutz für Ihren Alltag – ab 3,50 € im Monat." />
        <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <meta itemprop="price" content="3.50" />
          <meta itemprop="priceCurrency" content="EUR" />
          <meta itemprop="description" content="Grundschutz – Deckungssumme 5 Mio. €, Selbstbeteiligung 150 €" />
        </div>
        <dxp-card>
          <span slot="badge" style="background: #e3f2fd; color: #0066cc;">Empfohlen</span>
          <h3 slot="header-title">Privathaftpflicht</h3>
          <p slot="teaser-text">Umfassender Schutz für Ihren Alltag – ab 3,50 € im Monat.</p>
          <dxp-button slot="buttons">Jetzt abschließen</dxp-button>
        </dxp-card>
      </div>
      <div itemscope itemtype="https://schema.org/Product">
        <meta itemprop="name" content="Hausratversicherung" />
        <meta itemprop="description" content="Schützen Sie Ihr Hab und Gut gegen Einbruch, Feuer und Wasserschäden." />
        <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <meta itemprop="price" content="4.20" />
          <meta itemprop="priceCurrency" content="EUR" />
          <meta itemprop="description" content="Schutz gegen Einbruch, Feuer und Wasserschäden" />
        </div>
        <dxp-card>
          <h3 slot="header-title">Hausratversicherung</h3>
          <p slot="teaser-text">Schützen Sie Ihr Hab und Gut gegen Einbruch, Feuer und Wasserschäden.</p>
          <dxp-button slot="buttons" variant="secondary">Details ansehen</dxp-button>
        </dxp-card>
      </div>
    </div>
  </div>

  <!-- FLYOUT — annotated as ContactPoint -->
  <div style="margin: 2rem 0;" itemscope itemtype="https://schema.org/Organization">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Flyout</div>
    <div itemprop="contactPoint" itemscope itemtype="https://schema.org/ContactPoint">
      <meta itemprop="contactType" content="customer service" />
      <meta itemprop="telephone" content="+49-800-123-456-789" />
      <meta itemprop="hoursAvailable" content="Mo-Fr 08:00-18:00" />
    </div>
    <dxp-flyout flyout-position="left">
      <dxp-button slot="content" variant="secondary">Hilfe & Kontakt</dxp-button>
      <div slot="flyout" style="padding: 0.5rem;">
        <p style="margin: 0 0 0.5rem;"><strong>Kundenservice</strong></p>
        <p style="margin: 0;">Telefon: 0800 123 456 789</p>
        <p style="margin: 0;">Mo–Fr: 8:00–18:00 Uhr</p>
      </div>
    </dxp-flyout>
  </div>

  <!-- TARIFF COMPARISON — annotated as Offer list -->
  <div style="margin: 2rem 0;" itemscope itemtype="https://schema.org/WebPage">
    <div style="font-weight: 600; margin-bottom: 0.5rem; color: #666; font-size: 0.75rem; text-transform: uppercase;">Component: Tariff Comparison</div>
    <meta itemprop="name" content="Haftpflichtversicherung – Tarifvergleich" />
    <!-- Testimonial — Preis-Rauschen nahe Tarifbereich (keine schema:Offer-Annotation) -->
    <p style="font-size: 0.875rem; color: #555; border-left: 3px solid #ddd; padding: 0.5rem 0.75rem; margin: 0.5rem 0;">
      <em>„Ich spare jetzt <strong>12 € pro Monat</strong> gegenüber meinem alten Anbieter – super Preis-Leistung!“</em><br>
      <small>– Kundin Lisa M., München</small>
    </p>
    <!-- Veralteter Tarif — bewusst OHNE schema:Offer-Annotation -->
    <p style="font-size: 0.8rem; color: #aaa; margin-bottom: 0.75rem;">
      Unser früherer Einsteiger-Tarif war ab <strong>1,99 €</strong> / Monat erhältlich – dieser Tarif ist nicht mehr buchbar.
    </p>
    <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <meta itemprop="name" content="Haftpflicht Basis" />
      <meta itemprop="price" content="3.50" />
      <meta itemprop="priceCurrency" content="EUR" />
      <meta itemprop="description" content="Grundschutz – Deckungssumme 5 Mio. €, Selbstbeteiligung 150 €" />
    </div>
    <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <meta itemprop="name" content="Haftpflicht Komfort" />
      <meta itemprop="price" content="5.90" />
      <meta itemprop="priceCurrency" content="EUR" />
      <meta itemprop="description" content="Erweiterter Schutz – Deckungssumme 10 Mio. €, keine Selbstbeteiligung" />
    </div>
    <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <meta itemprop="name" content="Haftpflicht Premium" />
      <meta itemprop="price" content="9.80" />
      <meta itemprop="priceCurrency" content="EUR" />
      <meta itemprop="description" content="Rundum-Sorglos – Deckungssumme 50 Mio. €, keine Selbstbeteiligung" />
    </div>
    <dxp-tariff-comparison headline="Unsere Tarife im Vergleich" sub-headline="Wählen Sie den passenden Schutz für Ihre Bedürfnisse" tariffs='{"prefix":"ab","productName":"Haftpflicht","suffix":"€","tariffData":[{"id":"basis","name":"Basis","period":"monthly","premium":"3,50","description":"Grundschutz","buttons":[{"label":"Auswählen"}],"moduleConfigs":[{"moduleReference":"deckung","moduleReferenceUuid":"1","value":{"selectedText":"5 Mio. €"}},{"moduleReference":"selbstbeteiligung","moduleReferenceUuid":"2","value":{"selectedText":"150 €"}}]},{"id":"komfort","name":"Komfort","period":"monthly","premium":"5,90","highlighted":true,"overline":"Beliebteste Wahl","description":"Erweiterter Schutz","buttons":[{"label":"Auswählen"}],"moduleConfigs":[{"moduleReference":"deckung","moduleReferenceUuid":"1","value":{"selectedText":"10 Mio. €"}},{"moduleReference":"selbstbeteiligung","moduleReferenceUuid":"2","value":{"selectedText":"0 €"}}]},{"id":"premium","name":"Premium","period":"monthly","premium":"9,80","description":"Rundum-Sorglos","buttons":[{"label":"Auswählen"}],"moduleConfigs":[{"moduleReference":"deckung","moduleReferenceUuid":"1","value":{"selectedText":"50 Mio. €"}},{"moduleReference":"selbstbeteiligung","moduleReferenceUuid":"2","value":{"selectedText":"0 €"}}]}],"moduleGroups":[{"name":"Leistungen","modules":[{"moduleName":"deckung","name":"Deckungssumme","uuid":"1"},{"moduleName":"selbstbeteiligung","name":"Selbstbeteiligung","uuid":"2"}]}]}'></dxp-tariff-comparison>
  </div>

  <!-- ============================================ -->
  <!-- CROSS-SELL — kein semantischer Kontext (<div>)-->
  <!-- (keine Microdata-Annotation — absichtlich nicht als schema:Offer markiert) -->
  <!-- ============================================ -->
  <div style="margin: 2rem 0; padding: 1rem; background: #f9f9f9; border: 1px dashed #bbb; border-radius: 4px;">
    <p style="margin: 0 0 0.5rem; font-weight: 600; font-size: 0.875rem; color: #555;">Das könnte Sie auch interessieren</p>
    <p style="margin: 0 0 0.5rem;">Kombinieren Sie Ihren Schutz – <strong>KFZ-Haftpflicht</strong> bereits ab <strong>39,00 €</strong> monatlich verfügbar.</p>
    <ul style="margin: 0.25rem 0 0; padding-left: 1.5rem; font-size: 0.875rem;">
      <li>KFZ Basis – 39,00 € / Monat · Selbstbeteiligung: 500 €</li>
      <li>KFZ Komfort – 59,00 € / Monat · Selbstbeteiligung: 0 €</li>
    </ul>
  </div>

  <p style="margin-top: 2rem; padding: 1rem; background: #f0f0f0; border-left: 4px solid #9c27b0;">
    <a href="/control">← Baseline (keine Maßnahmen)</a> · 
    <a href="/combined">Alle Maßnahmen kombiniert →</a>
  </p>
</BaseLayout>
