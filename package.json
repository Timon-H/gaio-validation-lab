{
  "name": "gaio-validation-lab",
  "version": "1.0.0",
  "description": "Minimalist environment to validate and benchmark generative AI optimization approaches on web-components",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "astro": "astro",
    "test:bots": "node ./scripts/test-bots.mjs",
    "test:extract": "node ./scripts/test-content-extraction.mjs",
    "test:extract:persist": "node --env-file=.env ./scripts/test-content-extraction.mjs --persist",
    "test:all": "npm run test:bots && npm run test:extract",
    "evaluate": "node -e \"console.log('Usage: npm run evaluate:<provider> [-- --persist]\\n  Providers: openai | claude | gemini\\n  Examples:\\n    npm run evaluate:openai\\n    npm run evaluate:claude:persist');\"",
    "evaluate:openai": "node --env-file=.env ./scripts/evaluate-gaio.mjs --provider openai",
    "evaluate:claude": "node --env-file=.env ./scripts/evaluate-gaio.mjs --provider claude",
    "evaluate:gemini": "node --env-file=.env ./scripts/evaluate-gaio.mjs --provider gemini",
    "evaluate:openai:persist": "node --env-file=.env ./scripts/evaluate-gaio.mjs --provider openai --persist",
    "evaluate:claude:persist": "node --env-file=.env ./scripts/evaluate-gaio.mjs --provider claude --persist",
    "evaluate:gemini:persist": "node --env-file=.env ./scripts/evaluate-gaio.mjs --provider gemini --persist",
    "preview": "astro build && astro preview",
    "indexnow": "node ./scripts/indexnow.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Timon-H/gaio-validation-lab.git"
  },
  "keywords": [
    "gaio",
    "generative-ai-optimization",
    "ai-seo",
    "llm-seo",
    "geo",
    "generative-engine-optimization",
    "aio",
    "ai-optimization",
    "shadow-dom",
    "web-components",
    "lit",
    "lit-element",
    "declarative-shadow-dom",
    "dsd",
    "astro",
    "schema-org",
    "json-ld",
    "structured-data",
    "microdata",
    "semantic-html",
    "aria",
    "noscript",
    "ai-crawlers",
    "llm-extraction",
    "content-extraction",
    "gptbot",
    "claudebot",
    "googlebot",
    "perplexitybot",
    "benchmark",
    "validation",
    "thesis",
    "research"
  ],
  "author": "Timon Hargesheimer",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/Timon-H/gaio-validation-lab/issues"
  },
  "homepage": "https://github.com/Timon-H/gaio-validation-lab#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/vercel": "^9.0.4",
    "@google/generative-ai": "^0.24.1",
    "@lit-labs/ssr": "^4.0.0",
    "astro": "^5.17.1",
    "lit": "^3.3.2",
    "openai": "^6.25.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.10"
  },
  "overrides": {
    "path-to-regexp": ">=8.3.0",
    "lodash": ">=4.17.23"
  }
}
