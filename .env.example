# ============================================
# GAIO Validation Lab — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --------------------------------------------
# Supabase — Bot Tracking (middleware.ts)
# --------------------------------------------
# Used by the Astro middleware to log real AI crawler visits to the
# bot_logs table. Optional: if absent, bot detection still runs but
# visits are not persisted.
# Also used by evaluate.mjs --persist (llm_evaluation_results table)
# and test-extract.mjs --persist (extraction_results table).
# Get these from: Supabase Dashboard → Settings → API

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --------------------------------------------
# Local persistence (optional)
# --------------------------------------------
# Set GAIO_LOCAL_PERSIST=true to make all --persist writes use local
# JSONL files instead of Supabase REST inserts.
# Files are written under GAIO_LOCAL_DB_DIR (default: .gaio-local-db).

# GAIO_LOCAL_PERSIST=true
# GAIO_LOCAL_DB_DIR=.gaio-local-db

# --------------------------------------------
# Supabase — Content Extraction Persistence
# (test-extract.mjs --persist)
# --------------------------------------------
# Only required when running:  npm run test:extract:persist
# Dry-run mode (npm run test:extract) needs no Supabase credentials.
# Results are written to the extraction_results table.
# Uses the same SUPABASE_URL / SUPABASE_ANON_KEY values above.

# --------------------------------------------
# LLM Evaluation (evaluate.mjs)
# --------------------------------------------
# Only the key for the provider you intend to use is required.
# Run:  npm run evaluate:openai | evaluate:claude | evaluate:gemini

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# --------------------------------------------
# IndexNow Submission (indexnow.mjs)
# --------------------------------------------
# If you want to enable the indexnow.mjs script to submit URLs to search engines, you need to set the INDEXNOW_KEY and SITE_HOST variables.
# These are optional and only required if you plan to run the indexnow.mjs script.
# See: https://www.indexnow.org/documentation

INDEXNOW_KEY=292...
SITE_HOST=your-hosted-instance.vercel.app
