    given-names: Timon
repository-code: "https://github.com/Timon-H/gaio-validation-lab"
url: "https://gaio-validation-lab.vercel.app"
license: MIT
keywords:
  - generative AI optimization
  - GAIO
  - GEO
  - AI SEO
  - shadow DOM
  - web components
  - LLM extraction
